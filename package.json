{
  "name": "een-api-toolkit",
  "version": "0.0.6",
  "description": "EEN Video platform API v3.0 library for Vue 3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "typecheck": "vue-tsc --noEmit",
    "docs": "npm run docs:api && npm run docs:ai-context",
    "docs:api": "typedoc",
    "docs:ai-context": "npx tsx scripts/generate-ai-context.ts",
    "verify-package": "./scripts/verify-package.sh",
    "prepublishOnly": "npm run build && npm run docs",
    "prepare": "husky"
  },
  "peerDependencies": {
    "pinia": "^2.0.0 || ^3.0.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/tsconfig": "^0.8.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.0",
    "eslint-plugin-vue": "^10.6.0",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "pinia": "^3.0.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.15",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.16",
    "vue": "^3.4.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.1"
  },
  "keywords": [
    "eagle-eye-networks",
    "een",
    "api",
    "vue3",
    "typescript",
    "video-surveillance"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/klaushofrichter/een-api-toolkit"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
