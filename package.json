{
  "name": "een-api-toolkit",
  "version": "0.3.68",
  "description": "EEN Video platform API v3.0 library for Vue 3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "examples",
    "docs/AI-CONTEXT.md",
    "docs/ai-reference",
    ".claude/agents",
    "scripts/setup-agents.ts",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:examples": "./scripts/run-examples-e2e.sh",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "vue-tsc --noEmit",
    "docs": "npm run docs:api && npm run docs:ai-context",
    "docs:api": "typedoc",
    "docs:ai-context": "npx tsx scripts/generate-ai-context.ts",
    "docs:ai-context:single": "npx tsx scripts/generate-ai-context.ts --single",
    "verify-package": "./scripts/verify-package.sh",
    "prepublishOnly": "npm run build && npm run docs",
    "build:presentation": "node scripts/generate-presentation.cjs && npx @marp-team/marp-cli PRESENTATION.md -o PRESENTATION.html",
    "prepare": "husky",
    "setup-agents": "npx tsx scripts/setup-agents.ts"
  },
  "bin": {
    "een-setup-agents": "./scripts/setup-agents.ts"
  },
  "peerDependencies": {
    "pinia": "^3.0.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@marp-team/marp-cli": "^4.2.3",
    "@playwright/test": "1.58.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/tsconfig": "^0.8.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "pinia": "^3.0.4",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.15",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "~5.8.0",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.16",
    "vue": "^3.4.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.1"
  },
  "keywords": [
    "eagle-eye-networks",
    "een",
    "api",
    "vue3",
    "typescript",
    "video-surveillance"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/klaushofrichter/een-api-toolkit"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
